    "@fontsource/festive": "^5.2.8",
    "@fontsource/open-sans": "^5.2.7",
    "@google/genai": "^1.50.1",
    "@nestjs/common": "11.1.19",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.19",
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/swagger": "11.3.0",
    "@prisma/client": "7.7.0",
    "axios": "1.15.0",
    "core-js": "3.49.0",
    "debounce": "^3.0.0",
    "easy-peasy": "^6.1.1",
    "formik": "^2.4.9",
    "framer-motion": "12.38.0",
    "joi": "18.1.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-icons": "5.6.0",
    "react-router-dom": "7.14.1",
    "reflect-metadata": "0.2.2",
