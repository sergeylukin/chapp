{
  "name": "chapp",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "nx serve",
    "serve:api": "NODE_ENV=development nx serve api --host 0.0.0.0",
    "serve:web": "NODE_ENV=development nx serve front-website --host 0.0.0.0",
    "serve:all": "DB_HOST=localhost npm run prisma:apply && concurrently \"npm run serve:api\" \"npm run serve:web\"",
    "build:api": "npm run prisma:generate",
    "build:web": "npx nx build front-website",
    "build": "concurrently \"npm run build:api\" \"npm run build:web\"",
    "test": "npx nx test",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev --name init",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:apply": "npm run prisma:generate && npm run prisma:migrate && npm run prisma:seed"
  },
  "dependencies": {
    "@chakra-ui/icons": "2.2.4",
    "@chakra-ui/react": "3.34.0",
    "@dicebear/adventurer": "^9.4.2",
