{
  "name": "@chapp/front-website/theme",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/front-website/theme/src",
  "tags": [],
  "targets": {
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/front-website/theme/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/front-website/theme"],
      "options": {
        "jestConfig": "libs/front-website/theme/jest.config.js",
        "passWithNoTests": true
      }
    }
  }
}
