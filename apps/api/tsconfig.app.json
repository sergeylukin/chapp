{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "noEmitOnError": false,
    "baseUrl": ".",
    "outDir": "../../dist/apps/api",
    "module": "Node16",
    "target": "ES2020",
    "types": ["node"],
    "emitDecoratorMetadata": true
  },
  "exclude": ["**/*.spec.ts", "**/*.test.ts"],
  "include": ["**/*.ts"]
}